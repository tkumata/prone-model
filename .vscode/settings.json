{
  "idf.currentSetup": "${env:IDF_PATH}",
  "idf.openOcdConfigs": [
    "board/esp32s3-builtin.cfg"
  ],
  "idf.buildPath": "${workspaceFolder}/build-idf6",
  "idf.customExtraVars": {
    "IDF_TARGET": "esp32s3"
  },
  "C_Cpp.default.compileCommands": "${workspaceFolder}/build-idf6/compile_commands.json",
  "C_Cpp.default.configurationProvider": "ms-vscode.cpptools",
  "clangd.arguments": [
    "--background-index",
    "--query-driver=**",
    "--compile-commands-dir=${workspaceFolder}/build-idf6"
  ],
  "idf.flashType": "UART"
}
