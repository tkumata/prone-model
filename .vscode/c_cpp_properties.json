{
  "configurations": [
    {
      "name": "ESP-IDF",
      "compilerPath": "${env:IDF_TOOLCHAIN_PATH}/xtensa-esp32s3-elf-gcc",
      "compileCommands": "${workspaceFolder}/build-idf6/compile_commands.json",
      "includePath": [
        "${workspaceFolder}/main",
        "${workspaceFolder}/managed_components/**",
        "${workspaceFolder}/build-idf6/config",
        "${config:idf.currentSetup}/components/**",
        "${workspaceFolder}/**"
      ],
      "defines": [
        "ESP_PLATFORM",
        "IDF_TARGET=esp32s3"
      ],
      "intelliSenseMode": "gcc-x64",
      "browse": {
        "path": [
          "${workspaceFolder}/main",
          "${workspaceFolder}/managed_components",
          "${workspaceFolder}/build-idf6/config",
          "${config:idf.currentSetup}/components",
          "${workspaceFolder}"
        ],
        "limitSymbolsToIncludedHeaders": true
      }
    }
  ],
  "version": 4
}
